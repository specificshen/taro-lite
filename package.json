{
  "name": "taro",
  "version": "1.0.1",
  "description": "React 微信小程序（Skyline / glass-easel）现代化底座",
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "author": "Samuel Ouyang",
  "private": true,
  "license": "MIT",
  "keywords": [
    "taro",
    "react",
    "weapp",
    "skyline",
    "glass-easel"
  ],
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm -r --aggregate-output --filter=./packages/* prod",
    "build:serial": "pnpm -r --workspace-concurrency=1 --aggregate-output --filter=./packages/* prod",
    "debug": "bun scripts/debug.ts",
    "clear-all": "bun scripts/clean.ts --node-modules",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "pnpm --filter @spcsn/taro-components test:ci && pnpm --filter @spcsn/taro-cli test:ci -- cli.spec.ts build-config.spec.ts --runInBand",
    "updateSnapshot": "pnpm --if-present -r --aggregate-output --filter=./packages/* updateSnapshot",
    "verify:fixture:weapp": "pnpm -r --workspace-concurrency=1 --aggregate-output --filter @spcsn/taro-cli... --filter @spcsn/taro... run build && pnpm --filter @spcsn/fixture-taro-lite-sunshine-lab run build",
    "release:check": "bun scripts/check-release-readiness.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.3",
    "chalk": "^5.6.2",
    "concurrently": "^10.0.3",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">= 22.15.0"
  }
}
