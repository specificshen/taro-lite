{
  "name": "taro",
  "version": "1.0.0",
  "description": "React + Vite + 微信小程序（Skyline / glass-easel）现代化 fork",
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "author": "specificshen",
  "private": true,
  "license": "MIT",
  "keywords": [
    "taro",
    "react",
    "vite",
    "weapp",
    "skyline",
    "glass-easel"
  ],
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "main": "index.js",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm -r --aggregate-output --filter=./packages/* prod",
    "build:serial": "pnpm -r --workspace-concurrency=1 --aggregate-output --filter=./packages/* prod",
    "build:binding:debug": "pnpm --filter @spcsn/taro-binding run build:debug",
    "build:binding:release": "pnpm --filter @spcsn/taro-binding run build",
    "debug": "node scripts/debug.js",
    "format::rs": "cargo fmt --all",
    "clear-all": "node -e \"const fs=require('node:fs');const path=require('node:path');const remove=(dir)=>{if(!fs.existsSync(dir))return;for(const entry of fs.readdirSync(dir,{withFileTypes:true})){const full=path.join(dir,entry.name);if(entry.isDirectory()){if(entry.name==='node_modules')fs.rmSync(full,{recursive:true,force:true});else remove(full);}}};remove(process.cwd())\"",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "pnpm --filter @spcsn/taro-components test:ci && pnpm --filter @spcsn/taro-cli test:ci -- cli.spec.ts build-config.spec.ts --runInBand",
    "test:binding": "pnpm --filter @spcsn/taro-binding run test",
    "updateSnapshot": "pnpm --if-present -r --aggregate-output --filter=./packages/* updateSnapshot",
    "version": "pnpm run version:release && pnpm run version:git && pnpm run version:changelog",
    "version:release": "pnpm --parallel -r --aggregate-output --filter=./packages/* --filter=./npm/* --filter=./crates/native_binding exec npm version ${npm_package_version}",
    "version:git": "git add . && git commit -m \"chore(release): publish ${npm_package_version}\"",
    "version:changelog": "conventional-changelog -p angular",
    "artifacts": "pnpm --filter @spcsn/taro-helper --filter @spcsn/taro-binding run artifacts",
    "verify:bindings": "node scripts/verify-bindings.js",
    "verify:fixture:weapp": "pnpm --filter @spcsn/fixture-weapp-react19-vite-skyline run build",
    "release:check": "node scripts/check-release-readiness.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.19.19",
    "@vitest/coverage-istanbul": "^3.2.4",
    "conventional-changelog-cli": "^2.0.1",
    "rolldown": "^1.0.1",
    "tslib": "^2.6.2",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "packageExtensions": {
      "@ant-design/react-native": {
        "peerDependenciesMeta": {
          "@react-native-community/cameraroll": {
            "optional": true
          }
        }
      },
      "react-native-root-siblings": {
        "peerDependencies": {
          "react": "19.2.0"
        },
        "peerDependenciesMeta": {
          "react": {
            "optional": true
          }
        }
      }
    },
    "overrides": {
      "browserslist": "^4.24.4"
    }
  },
  "engines": {
    "node": ">= 22"
  }
}
