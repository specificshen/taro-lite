{
  "name": "taro",
  "version": "0.1.0",
  "description": "React + Vite + 微信小程序（Skyline / glass-easel）现代化 fork",
  "homepage": "https://github.com/specificshen/taro#readme",
  "author": "specificshen",
  "private": true,
  "license": "MIT",
  "keywords": [
    "taro",
    "react",
    "vite",
    "weapp",
    "skyline",
    "glass-easel"
  ],
  "bugs": {
    "url": "https://github.com/specificshen/taro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro.git"
  },
  "main": "index.js",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm -r --aggregate-output --filter=./packages/* prod",
    "build:serial": "pnpm -r --workspace-concurrency=1 --aggregate-output --filter=./packages/* prod",
    "build:binding:debug": "pnpm --filter @spcsn/taro-binding run build:debug",
    "build:binding:release": "pnpm --filter @spcsn/taro-binding run build",
    "debug": "node scripts/debug.js",
    "format::rs": "cargo fmt --all",
    "clear-all": "rimraf **/node_modules",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "pnpm --filter @spcsn/taro-components test:ci && pnpm --filter @spcsn/babel-plugin-transform-taroapi test:ci && pnpm --filter @spcsn/taro-cli test:ci -- cli.spec.ts build-config.spec.ts --runInBand",
    "test:binding": "pnpm --filter @spcsn/taro-binding run test",
    "updateSnapshot": "pnpm --if-present -r --aggregate-output --filter=./packages/* updateSnapshot",
    "version": "run-s version:*",
    "version:release": "pnpm --parallel -r --aggregate-output --filter=./packages/* --filter=./npm/* --filter=./crates/native_binding exec npm version ${npm_package_version}",
    "version:git": "git add . && git commit -m \"chore(release): publish ${npm_package_version}\"",
    "version:changelog": "conventional-changelog -p angular",
    "artifacts": "pnpm --filter @spcsn/taro-helper --filter @spcsn/taro-binding run artifacts",
    "verify:bindings": "node scripts/verify-bindings.js"
  },
  "taroTemp": [
    "@types/babel__core",
    "@types/babel-types",
    "@types/babel__traverse",
    "@babel/cli",
    "@babel/core",
    "@babel/helper-plugin-utils",
    "@babel/parser",
    "@babel/plugin-transform-class-properties",
    "@babel/plugin-proposal-decorators",
    "@babel/plugin-proposal-do-expressions",
    "@babel/plugin-proposal-object-rest-spread",
    "@babel/plugin-syntax-dynamic-import",
    "@babel/plugin-transform-react-jsx",
    "@babel/plugin-transform-runtime",
    "@babel/preset-env",
    "@babel/preset-react",
    "@babel/preset-typescript",
    "@babel/runtime",
    "@babel/traverse",
    "@babel/types",
    "babel-plugin-syntax-jsx",
    "babel-preset-power-assert",
    "'@types/react': '^19.2.14',",
    "'@types/react-dom': '^19.2.3',",
    "'@types/react-reconciler': '0.33.0',"
  ],
  "devDependencies": {
    "@babel/cli": "^7.24.1",
    "@babel/core": "^7.24.4",
    "@babel/preset-env": "^7.24.4",
    "@babel/runtime": "^7.24.4",
    "@biomejs/biome": "^2.4.15",
    "@types/debug": "^4.1.5",
    "@types/fs-extra": "^8.0.1",
    "@types/history": "^4.7.5",
    "@types/inquirer": "^8.2.1",
    "@types/jest": "^29.5.0",
    "@types/less": "^3.0.2",
    "@types/node": "^22.19.19",
    "@types/postcss-import": "^14.0.0",
    "@types/postcss-url": "^10.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-reconciler": "^0.33.0",
    "@types/resolve": "^1.20.6",
    "@types/sass": "1.43.1",
    "@types/tapable": "^1",
    "@types/webpack": "^4.41.26",
    "@types/webpack-dev-server": "^3.11.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-istanbul": "^3.2.4",
    "babel-jest": "^29.7.0",
    "babel-plugin-syntax-jsx": "6.18.0",
    "babel-preset-power-assert": "3.0.0",
    "@spcsn/babel-preset-taro": "workspace:*",
    "chalk": "^4.1.2",
    "concurrently": "^8.2.2",
    "conventional-changelog-cli": "^2.0.1",
    "core-js": "^3.6.5",
    "cross-env": "^7.0.2",
    "escodegen": "^2.0.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-environment-jsdom": "^29.6.4",
    "jest-environment-node": "^29.7.0",
    "jest-light-runner": "^0.6.0",
    "jsdom": "^24.0.0",
    "minimist": "^1.2.8",
    "mkdirp": "^3.0.1",
    "npm-run-all": "^4.1.2",
    "postcss": "^8.5.6",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.3",
    "power-assert": "^1.6.1",
    "prop-types": "^15.7.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^5.0.0",
    "rolldown": "^1.0.1",
    "rollup": "^4.16.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.1",
    "tslib": "^2.6.2",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "packageExtensions": {
      "@ant-design/react-native": {
        "peerDependenciesMeta": {
          "@react-native-community/cameraroll": {
            "optional": true
          }
        }
      },
      "react-native-root-siblings": {
        "peerDependencies": {
          "react": "19.2.0"
        },
        "peerDependenciesMeta": {
          "react": {
            "optional": true
          }
        }
      }
    },
    "overrides": {
      "browserslist": "^4.24.4"
    }
  },
  "engines": {
    "node": ">= 22"
  }
}
