{
  "name": "@spcsn/taro-api",
  "version": "0.1.2",
  "description": "Taro common API",
  "author": "O2Team",
  "license": "MIT",
  "browser": "dist/index.js",
  "main:h5": "dist/index.esm.js",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "directories": {
    "lib": "lib",
    "test": "tests"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NervJS/taro.git"
  },
  "scripts": {
    "prod": "pnpm run build",
    "prebuild": "pnpm run clean",
    "build": "pnpm run build:types && pnpm run rolldown --environment NODE_ENV:production",
    "build:types": "tsc --emitDeclarationOnly --declaration",
    "clean": "rimraf ./dist",
    "dev": "concurrently \"pnpm run build:types -- --watch\" \"pnpm run rolldown --environment NODE_ENV:development -w\"",
    "rolldown": "rolldown --config rolldown.config.mjs",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:dev": "vitest"
  },
  "bugs": {
    "url": "https://github.com/NervJS/taro/issues"
  },
  "engines": {
    "node": ">= 22"
  },
  "devDependencies": {
    "@spcsn/taro-runtime": "workspace:*",
    "@spcsn/taro-shared": "workspace:*",
    "lodash": "4.17.21"
  },
  "peerDependencies": {
    "@spcsn/taro-runtime": "workspace:*",
    "@spcsn/taro-shared": "workspace:*"
  }
}
