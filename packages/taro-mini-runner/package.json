{
  "name": "@spcsn/taro-mini-runner",
  "version": "1.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./framework-react": {
      "types": "./dist/react-framework/index.d.ts",
      "require": "./dist/react-framework/index.js",
      "default": "./dist/react-framework/index.js"
    }
  },
  "author": "Samuel Ouyang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "files": [
    "dist"
  ],
  "scripts": {
    "prod": "pnpm run build",
    "clean": "bun ../../scripts/clean.ts dist",
    "dev": "pnpm run copy:template && tsc -w",
    "build": "pnpm run clean && tsc && pnpm run copy:template",
    "copy:template": "bun ./scripts/copy-template.ts"
  },
  "dependencies": {
    "@spcsn/taro-helper": "1.0.1",
    "@spcsn/taro-runtime": "1.0.1",
    "@spcsn/taro-shared": "1.0.1",
    "acorn": "^8.11.3",
    "acorn-walk": "^8.3.2",
    "autoprefixer": "^10.4.19",
    "html-minifier": "^4.0.0",
    "lodash": "^4.17.21",
    "picomatch": "^4.0.2",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-reconciler": "0.33.0",
    "regenerator-runtime": "0.11",
    "sax": "1.6.0",
    "terser": "^5.30.4",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.13",
    "vite-plugin-static-copy": "^4.1.0"
  },
  "devDependencies": {
    "@spcsn/taro": "1.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^22.19.19",
    "@types/react-reconciler": "^0.33.0",
    "typescript": "~6.0.3"
  }
}
