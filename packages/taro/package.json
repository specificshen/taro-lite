{
  "name": "@spcsn/taro",
  "version": "1.1.0",
  "description": "SPCSN Taro runtime API entry",
  "author": "Samuel Ouyang",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types/compile": {
      "types": "./types/compile/index.d.ts"
    },
    "./types/compile/compiler": {
      "types": "./types/compile/compiler.d.ts"
    },
    "./types/compile/config/plugin": {
      "types": "./types/compile/config/plugin.d.ts"
    },
    "./types/compile/hooks": {
      "types": "./types/compile/hooks.d.ts"
    },
    "./types/compile/viteCompilerContext": {
      "types": "./types/compile/viteCompilerContext.d.ts"
    },
    "./types/*": "./types/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "prod": "pnpm run build",
    "prepack": "pnpm run build",
    "prebuild": "pnpm run clean",
    "build": "pnpm run rolldown --environment NODE_ENV:production",
    "clean": "bun ../../scripts/clean.ts dist",
    "dev": "pnpm run rolldown --environment NODE_ENV:development -w",
    "rolldown": "rolldown --config rolldown.config.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "keywords": [
    "taro"
  ],
  "engines": {
    "node": ">= 22.15.0"
  },
  "dependencies": {
    "@spcsn/taro-runtime": "workspace:*",
    "@spcsn/taro-shared": "workspace:*"
  },
  "devDependencies": {
    "@spcsn/taro-components": "workspace:*",
    "rolldown": "^1.1.1"
  },
  "peerDependencies": {
    "@spcsn/taro-components": "^1.1.0",
    "@types/react": "^19"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  }
}
