{
  "name": "@spcsn/taro",
  "version": "1.0.0",
  "description": "Taro framework",
  "author": "O2Team",
  "license": "MIT",
  "main": "index.js",
  "types": "types/index.d.ts",
  "typings": "types/index.d.ts",
  "files": [
    "index.js",
    "dist",
    "types"
  ],
  "scripts": {
    "prod": "pnpm run build",
    "prebuild": "pnpm run clean",
    "build": "pnpm run rolldown --environment NODE_ENV:production",
    "clean": "rimraf ./dist",
    "dev": "pnpm run rolldown --environment NODE_ENV:development -w",
    "rolldown": "rolldown --config rolldown.config.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NervJS/taro.git"
  },
  "keywords": [
    "taro"
  ],
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@spcsn/taro-runtime": "workspace:*",
    "@spcsn/taro-shared": "workspace:*"
  },
  "devDependencies": {
    "@spcsn/taro-components": "workspace:*",
    "@spcsn/taro-helper": "workspace:*",
    "@spcsn/taro-shared": "workspace:*"
  },
  "peerDependencies": {
    "@spcsn/taro-components": "workspace:*",
    "@types/react": "^19"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  }
}
