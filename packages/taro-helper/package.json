{
  "name": "@spcsn/taro-helper",
  "version": "1.0.1",
  "description": "SPCSN Taro helper utilities",
  "author": "Samuel Ouyang",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prod": "pnpm run build",
    "clean": "bun ../../scripts/clean.ts dist",
    "prebuild": "pnpm run clean",
    "build": "tsc",
    "dev": "tsc -w",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "taro"
  ],
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "engines": {
    "node": ">= 22.15.0"
  },
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@swc/core": "^1.15.41",
    "@swc/register": "0.1.10",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cross-spawn": "^7.0.6",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "resolve": "^1.22.12"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/cross-spawn": "^6.0.6",
    "@types/debug": "^4.1.13",
    "@types/node": "^25.9.3",
    "@types/resolve": "^1.20.6",
    "@vitest/coverage-istanbul": "^4.1.8",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
