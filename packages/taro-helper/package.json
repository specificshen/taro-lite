{
  "name": "@spcsn/taro-helper",
  "version": "1.0.0",
  "description": "Taro Helper",
  "author": "O2Team",
  "license": "MIT",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prod": "pnpm run build",
    "clean": "bun ../../scripts/clean.ts dist",
    "prebuild": "pnpm run clean",
    "build": "tsc",
    "postbuild": "pnpm run swc:backup",
    "dev": "tsc -w",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "artifacts": "bun scripts/artifacts.ts",
    "swc:backup": "bun scripts/backup.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "files": [
    "index.js",
    "dist",
    "types",
    "swc"
  ],
  "keywords": [
    "taro"
  ],
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "engines": {
    "node": ">= 22"
  },
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "dependencies": {
    "@babel/core": "^7.24.4",
    "@swc/core": "1.3.96",
    "@swc/register": "0.1.10",
    "chalk": "^5.6.2",
    "chokidar": "^3.6.0",
    "cross-spawn": "^7.0.3",
    "debug": "^4.3.4",
    "dotenv": "^16.4.5",
    "dotenv-expand": "^11.0.6",
    "lodash": "^4.17.21",
    "resolve": "^1.22.8"
  },
  "devDependencies": {
    "@spcsn/taro": "workspace:*",
    "@types/babel__core": "^7.20.5",
    "@types/debug": "^4.1.5",
    "@types/node": "^22.19.19",
    "@types/resolve": "^1.20.6",
    "@vitest/coverage-istanbul": "^3.2.4",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  }
}
