{
  "name": "@spcsn/taro-components",
  "version": "1.0.0",
  "description": "Taro 组件库",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types/*": "./types/*",
    "./global.css": "./global.css"
  },
  "types": "types/index.d.ts",
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "files": [
    "dist",
    "types",
    "global.css"
  ],
  "scripts": {
    "prod": "pnpm run build:ci",
    "build:ci": "pnpm run build",
    "build": "pnpm run build:runtime && pnpm run sync:types",
    "build:runtime": "tsc -p tsconfig.json",
    "sync:types": "pnpm run tsx --files scripts/json-schema-to-types.ts",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "tsx": "ts-node --skipIgnore"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@spcsn/taro-shared": "workspace:*",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@spcsn/taro-helper": "workspace:*",
    "@babel/generator": "^7.21.4",
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.21.4",
    "@babel/types": "^7.23.0",
    "change-case": "^4.1.2",
    "csstype": "^3.1.1",
    "lodash": "^4.17.21",
    "miniapp-types": "1.6.0",
    "tsconfig-paths": "^4.2.0",
    "vitest": "^3.2.4"
  }
}
