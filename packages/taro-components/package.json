{
  "name": "@spcsn/taro-components",
  "version": "1.2.0",
  "description": "Taro 组件库",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types/*": "./types/*",
    "./global.css": "./global.css",
    "./package.json": "./package.json"
  },
  "types": "types/index.d.ts",
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "files": [
    "dist",
    "types",
    "global.css"
  ],
  "scripts": {
    "prod": "pnpm run build:ci",
    "prepack": "pnpm run build",
    "build:ci": "pnpm run build",
    "build": "pnpm run build:runtime && pnpm run sync:types",
    "build:runtime": "tsc -p tsconfig.json",
    "sync:types": "bun scripts/json-schema-to-types.ts",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "author": "Samuel Ouyang",
  "license": "MIT",
  "engines": {
    "node": ">= 22.15.0"
  },
  "peerDependencies": {
    "react": "^19",
    "@types/react": "^19"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@vitest/coverage-istanbul": "^4.1.8",
    "miniapp-types": "1.6.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
