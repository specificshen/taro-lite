{
  "name": "@spcsn/taro-cli",
  "version": "1.1.1",
  "description": "SPCSN Taro Lite CLI for React WeApp mini programs",
  "author": "Samuel Ouyang",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prod": "pnpm run build",
    "prepack": "pnpm run build",
    "pretest": "pnpm run build",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:dev": "vitest",
    "test:coverage": "vitest run --coverage",
    "updateSnapshot": "vitest run --update",
    "prebuild": "pnpm run clean",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -w",
    "clean": "bun ../../scripts/clean.ts dist"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "bin": {
    "taro": "bin/taro"
  },
  "keywords": [
    "taro",
    "weapp"
  ],
  "engines": {
    "node": ">= 22.15.0"
  },
  "dependencies": {
    "@spcsn/taro-components": "workspace:*",
    "@spcsn/taro-helper": "workspace:*",
    "@spcsn/taro-mini-runner": "workspace:*",
    "@spcsn/taro-service": "workspace:*",
    "@spcsn/taro-shared": "workspace:*",
    "adm-zip": "^0.5.17",
    "download-git-repo": "^3.0.2",
    "inquirer": "^14.0.2",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@spcsn/taro": "workspace:*",
    "@types/adm-zip": "^0.5.8",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.9.3",
    "@vitest/coverage-istanbul": "^4.1.8",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
