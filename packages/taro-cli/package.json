{
  "name": "@spcsn/taro-cli",
  "version": "1.0.0",
  "description": "SPCSN Taro Lite CLI for React + Vite + WeApp",
  "author": "specificshen",
  "license": "MIT",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prod": "pnpm run build",
    "postinstall": "node postinstall.js",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:dev": "vitest",
    "test:coverage": "vitest run --coverage",
    "updateSnapshot": "vitest run --update",
    "prebuild": "pnpm run clean",
    "build": "tsc",
    "dev": "tsc -w",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "files": [
    "bin",
    "src",
    "dist",
    "templates",
    "postinstall.js",
    "index.js",
    "global.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "bin": {
    "taro": "bin/taro"
  },
  "keywords": [
    "taro",
    "weapp"
  ],
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@spcsn/taro-components": "workspace:*",
    "@spcsn/taro-helper": "workspace:*",
    "@spcsn/taro-service": "workspace:*",
    "@spcsn/taro-shared": "workspace:*",
    "@spcsn/taro-vite-runner": "workspace:*",
    "@spcsn/taro-binding": "workspace:*",
    "adm-zip": "^0.5.12",
    "axios": "^1.6.8",
    "download-git-repo": "^3.0.2",
    "inquirer": "^8.2.6",
    "minimist": "^1.2.8",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@spcsn/taro": "workspace:*"
  }
}
