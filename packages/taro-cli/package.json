{
  "name": "@spcsn/taro-cli",
  "version": "0.1.0",
  "description": "cli tool for taro",
  "author": "O2Team",
  "license": "MIT",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prod": "pnpm run build",
    "postinstall": "node postinstall.js",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:dev": "vitest",
    "test:coverage": "vitest run --coverage",
    "updateSnapshot": "vitest run --update",
    "prebuild": "pnpm run clean",
    "build": "tsc || true",
    "dev": "tsc -w",
    "clean": "rimraf dist"
  },
  "files": [
    "bin",
    "src",
    "dist",
    "templates",
    "postinstall.js",
    "index.js",
    "global.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NervJS/taro.git"
  },
  "bin": {
    "taro": "bin/taro"
  },
  "keywords": [
    "taro",
    "weapp"
  ],
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@spcsn/babel-preset-taro": "workspace:*",
    "@spcsn/taro-helper": "workspace:*",
    "@spcsn/taro-plugin-framework-react": "workspace:*",
    "@spcsn/taro-plugin-generator": "workspace:*",
    "@spcsn/taro-plugin-platform-weapp": "workspace:*",
    "@spcsn/taro-service": "workspace:*",
    "@spcsn/taro-shared": "workspace:*",
    "@spcsn/taro-vite-runner": "workspace:*",
    "@spcsn/taro-binding": "workspace:*",
    "adm-zip": "^0.5.12",
    "axios": "^1.6.8",
    "cli-highlight": "^2.1.11",
    "download-git-repo": "^3.0.2",
    "envinfo": "^7.12.0",
    "inquirer": "^8.2.6",
    "latest-version": "^5.1.0",
    "minimist": "^1.2.8",
    "ora": "^5.4.1",
    "semver": "^7.6.0",
    "validate-npm-package-name": "^5.0.0"
  },
  "devDependencies": {
    "@babel/types": "^7.24.0",
    "@spcsn/taro": "workspace:*",
    "@spcsn/taro-plugin-platform-weapp": "workspace:*",
    "@types/babel__traverse": "^7.20.6"
  }
}
