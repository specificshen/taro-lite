{
  "name": "@spcsn/taro-cli",
  "version": "1.0.1",
  "description": "SPCSN Taro Lite CLI for React WeApp mini programs",
  "author": "Samuel Ouyang",
  "license": "MIT",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prod": "pnpm run build",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:dev": "vitest",
    "test:coverage": "vitest run --coverage",
    "updateSnapshot": "vitest run --update",
    "prebuild": "pnpm run clean",
    "build": "tsc",
    "dev": "tsc -w",
    "clean": "bun ../../scripts/clean.ts dist"
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "index.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "bin": {
    "taro": "bin/taro"
  },
  "keywords": [
    "taro",
    "weapp"
  ],
  "engines": {
    "node": ">= 22.15.0"
  },
  "dependencies": {
    "@spcsn/taro-components": "1.0.1",
    "@spcsn/taro-helper": "1.0.1",
    "@spcsn/taro-service": "1.0.1",
    "@spcsn/taro-shared": "1.0.1",
    "@spcsn/taro-mini-runner": "1.0.1",
    "adm-zip": "^0.5.12",
    "download-git-repo": "^3.0.2",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@spcsn/taro": "1.0.1",
    "@types/inquirer": "^8.2.1",
    "@types/node": "^22.19.19",
    "@vitest/coverage-istanbul": "^3.2.4",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  }
}
