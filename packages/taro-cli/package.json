{
  "name": "@spcsn/taro-cli",
  "version": "1.2.0",
  "description": "SPCSN Taro Lite CLI for React WeApp mini programs",
  "author": "Samuel Ouyang",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prod": "pnpm run build",
    "prepack": "pnpm run build",
    "pretest": "pnpm run build",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:dev": "vitest",
    "test:coverage": "vitest run --coverage",
    "updateSnapshot": "vitest run --update",
    "prebuild": "pnpm run clean",
    "build": "tsc && bun ./scripts/fix-esm-imports.ts dist",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -w",
    "clean": "bun ../../scripts/clean.ts dist"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro-lite.git"
  },
  "bugs": {
    "url": "https://github.com/specificshen/taro-lite/issues"
  },
  "homepage": "https://github.com/specificshen/taro-lite#readme",
  "bin": {
    "taro": "bin/taro"
  },
  "keywords": [
    "taro",
    "weapp"
  ],
  "engines": {
    "node": ">= 22.15.0"
  },
  "dependencies": {
    "@spcsn/taro": "workspace:*",
    "@swc/core": "^1.15.41",
    "@swc/register": "0.1.10",
    "@vitejs/plugin-react": "^6.0.2",
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "adm-zip": "^0.5.17",
    "autoprefixer": "^10.5.0",
    "browserslist": "^4.28.2",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cross-spawn": "^7.0.6",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",

    "inquirer": "^14.0.2",
    "joi": "^18.2.1",
    "lightningcss": "^1.32.0",
    "lodash": "^4.18.1",
    "ora": "^9.4.0",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-reconciler": "0.33.0",
    "regenerator-runtime": "~0.14.1",
    "resolve": "^1.22.12",
    "sax": "1.6.0",
    "tapable": "^2.3.3",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "^4.1.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/cross-spawn": "^6.0.6",
    "@types/debug": "^4.1.13",
    "@types/inquirer": "^9.0.9",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-reconciler": "^0.33.0",
    "@types/resolve": "^1.20.6",
    "@types/sax": "1.2.7",
    "@vitest/coverage-istanbul": "^4.1.8",
    "typescript": "~7.0.1-rc",
    "vitest": "^4.1.8"
  }
}
