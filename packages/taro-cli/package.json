{
  "name": "@spcsn/taro-cli",
  "version": "1.0.0",
  "description": "SPCSN Taro Lite CLI for React + Vite + WeApp",
  "author": "specificshen",
  "license": "MIT",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prod": "pnpm run build",
    "postinstall": "node postinstall.js",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:dev": "vitest",
    "test:coverage": "vitest run --coverage",
    "updateSnapshot": "vitest run --update",
    "prebuild": "pnpm run clean",
    "build": "tsc || true",
    "dev": "tsc -w",
    "clean": "rimraf dist"
  },
  "files": [
    "bin",
    "babel-preset-taro",
    "src",
    "dist",
    "templates",
    "postinstall.js",
    "index.js",
    "global.d.ts",
    "plugin.d.ts",
    "plugin.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/specificshen/taro.git"
  },
  "bin": {
    "taro": "bin/taro"
  },
  "keywords": [
    "taro",
    "weapp"
  ],
  "engines": {
    "node": ">= 22"
  },
  "dependencies": {
    "@babel/core": "^7.24.4",
    "@spcsn/taro-components": "workspace:*",
    "@spcsn/taro-helper": "workspace:*",
    "@spcsn/taro-service": "workspace:*",
    "@spcsn/taro-shared": "workspace:*",
    "@spcsn/taro-vite-runner": "workspace:*",
    "@spcsn/taro-binding": "workspace:*",
    "@babel/generator": "7.24.4",
    "@babel/helper-plugin-utils": "^7.24.8",
    "@babel/parser": "7.24.4",
    "@babel/plugin-proposal-decorators": "^7.24.1",
    "@babel/plugin-transform-class-properties": "^7.24.1",
    "@babel/plugin-transform-runtime": "^7.24.3",
    "@babel/preset-env": "^7.24.4",
    "@babel/preset-react": "^7.24.1",
    "@babel/preset-typescript": "^7.24.1",
    "@babel/runtime": "^7.24.4",
    "@babel/runtime-corejs3": "^7.24.4",
    "@babel/traverse": "7.24.1",
    "@babel/types": "7.24.0",
    "@rnx-kit/babel-preset-metro-react-native": "^1.1.8",
    "adm-zip": "^0.5.12",
    "axios": "^1.6.8",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-plugin-transform-imports-api": "1.0.0",
    "cli-highlight": "^2.1.11",
    "core-js": "^3.36.1",
    "dedent": "^1.6.0",
    "download-git-repo": "^3.0.2",
    "envinfo": "^7.12.0",
    "inquirer": "^8.2.6",
    "latest-version": "^5.1.0",
    "minimist": "^1.2.8",
    "ora": "^5.4.1",
    "react-refresh": "^0.14.0",
    "semver": "^7.6.0",
    "ts-morph": "^26.0.0",
    "validate-npm-package-name": "^5.0.0"
  },
  "devDependencies": {
    "@spcsn/taro": "workspace:*",
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.6"
  }
}
