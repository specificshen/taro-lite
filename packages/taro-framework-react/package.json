{
  "name": "@spcsn/taro-plugin-framework-react",
  "version": "0.1.0",
  "description": "React 框架插件",
  "author": "O2Team",
  "homepage": "https://github.com/nervjs/taro",
  "license": "MIT",
  "main": "index.js",
  "keywords": [
    "taro"
  ],
  "files": [
    "index.js",
    "dist"
  ],
  "sideEffects": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NervJS/taro.git"
  },
  "scripts": {
    "prod": "pnpm run build",
    "prebuild": "run-s clean",
    "build": "pnpm run rolldown --environment NODE_ENV:production",
