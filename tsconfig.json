{
  "compileOnSave": true,
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "module": "ESNext",
    "noImplicitAny": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "removeComments": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["scripts/**/*.ts", "packages/*/scripts/**/*.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "archive", "fixtures"]
}
