    "./package.json": "./package.json"
  },
  "scripts": {
    "prod": "echo \"source moved to packages/taro-cli/src/internal\"",
    "prepack": "echo \"source moved to packages/taro-cli/src/internal\"",
    "prebuild": "echo \"source moved to packages/taro-cli/src/internal\"",
    "clean": "bun ../../../scripts/clean.ts dist",
    "dev": "echo \"source moved to packages/taro-cli/src/internal\"",
    "build": "echo \"source moved to packages/taro-cli/src/internal\""
  },
  "files": [
    "dist"
  ],
  "keywords": [
