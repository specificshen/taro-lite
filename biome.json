{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!dist",
      "!coverage",
      "!archive",
      "!node_modules",
      "!oh_modules",
      "!**/*.d.ts",
      "!**/*.ets",
      "!packages/taro-cli/src/__tests__/fixtures",
      "!packages/taro-cli/templates",
      "!packages/taro-helper/swc"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false
    }
  },
  "assist": {
    "enabled": false
  }
}
