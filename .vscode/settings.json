    "dotenv",
    "emnapi",
    "hapi",
    "htmltransform",
    "interceptorify",
    "jridgewell",
    "KONSOLE",
    "lightningcss",
    "LOGNAME",
    "miniapp",
    "Nerv",
    "onattribute",
    "Ouyang",
    "picomatch",
    "prerender",
    "pxtransform",
    "RRGGBBAA",
    "spcsn",
    "specificshen",
    "tapable",
    "taroapi",
