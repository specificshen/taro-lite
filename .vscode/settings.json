{
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "search.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/yarn.lock": true,
    "**/__snapshots__": true
  },
  "files.associations": {
    "*.ets": "typescript",
    "packages/taro-cli/templates/**/*.js": "plaintext"
  },
  "cSpell.words": [
    "Arrs",
    "cameraroll",
    "cnpm",
    "DOMTERM",
    "htmltransform",
    "KONSOLE",
    "LOGNAME",
    "miniapp",
    "Nerv",
    "onattribute",
    "Ouyang",
    "prerender",
    "pxtransform",
    "spcsn",
    "specificshen",
    "taroapi",
    "tarojs",
    "weapp"
  ]
}
